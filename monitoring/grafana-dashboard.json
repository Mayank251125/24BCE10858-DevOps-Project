      "datasource": {
        "type": "graphite",
        "uid": "graphite"
      },
      "targets": [
        {
          "target": "disk.free.path.*",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "decbytes"
        }
      }
