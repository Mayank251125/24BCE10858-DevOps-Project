      "id": 4,
      "title": "CPU Usage (System Core Load)",
      "type": "timeseries",
      "datasource": {
        "type": "graphite",
        "uid": "graphite"
      },
      "targets": [
        {
          "target": "scale(system.cpu.usage, 100)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth"
          },
          "unit": "percent"
        }
      }
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 4
      },
      "id": 5,
      "title": "Memory Usage (JVM Used)",
      "type": "timeseries",
      "datasource": {
        "type": "graphite",
        "uid": "graphite"
      },
      "targets": [
        {
          "target": "scale(sumSeries(jvm.memory.used.area.heap.id.*), 0.00000095367)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line"
          },
          "unit": "mbytes"
        }
      }
    },
